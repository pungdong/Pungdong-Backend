# 로컬 개발용 MySQL 연결. 도커 컴포즈에서 띄운 컨테이너 가정.
# 실제 사용:
#   cp src/main/resources/database.yml.example src/main/resources/database.yml
# database.yml 자체는 .gitignore'd (실제 운영 자격증명을 위해).

spring:
  datasource:
    # connectionTimeZone=UTC (+forceConnectionTimeZoneToSession) — instant(OffsetDateTime) 을 UTC 로 저장/조회.
    # application.yml 의 hibernate.jdbc.time_zone=UTC 와 한 쌍. (옛 serverTimezone=Asia/Seoul 에서 전환 — 글로벌화 UTC 통일, time-handling.md.)
    url: jdbc:mysql://localhost:3306/pungdong?characterEncoding=UTF-8&connectionTimeZone=UTC&forceConnectionTimeZoneToSession=true&useSSL=false&allowPublicKeyRetrieval=true
    username: pungdong
    password: pungdongpw
    driver-class-name: com.mysql.cj.jdbc.Driver
