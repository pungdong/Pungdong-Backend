# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored. Production values come from the deploy environment
# (ECS task definition / Parameter Store / etc., decided in Phase 2).

# JWT signing secret. Generate a strong value, e.g.:
#   openssl rand -base64 32
JWT_SECRET=

# Gmail (or SMTP) account used for sending verification emails.
# For Gmail with 2FA: create an App Password at
# https://myaccount.google.com/apppasswords and put it here (NOT your
# regular Google password).
ADMIN_MAIL_ID=
ADMIN_MAIL_PASSWORD=

# Elasticsearch endpoint. Required only when running with the default
# (non-test) profile. Tests stub ES out entirely; see
# src/test/.../config/TestElasticSearchConfig.java.
ELASTICSEARCH_URI=

# Firebase Admin SDK service account JSON path. OPTIONAL.
# - If set, the app initialises Firebase and routes notifications through
#   the real FCM API.
# - If unset, NotificationDeliveryWorker falls back to LoggingFcmGateway,
#   which logs the would-be notification and returns SUCCESS. This lets
#   bootRun work without a Firebase project for local dev.
# Get the JSON from Firebase Console -> Project settings -> Service accounts
# -> Generate new private key. Save outside the repo and reference here.
FIREBASE_CREDENTIALS_PATH=
