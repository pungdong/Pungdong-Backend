# Copy this file to .env.local and fill in real values for local development.
# .env.local is gitignored. Production values come from the deploy environment
# (ECS task definition / Parameter Store / etc., decided in Phase 2).

# JWT signing secret. Generate a strong value, e.g.:
#   openssl rand -base64 32
JWT_SECRET=

# Gmail (or SMTP) account used for sending verification emails.
# For Gmail with 2FA: create an App Password at
# https://myaccount.google.com/apppasswords and put it here (NOT your
# regular Google password).
ADMIN_MAIL_ID=
ADMIN_MAIL_PASSWORD=

# --- Firebase / FCM ---
# Set FIREBASE_ENABLED=true to route notifications through the real FCM API.
# Leave unset (default) and NotificationDeliveryWorker falls back to
# LoggingFcmGateway, which just logs the would-be notification and returns
# SUCCESS. This lets bootRun work without any Firebase setup for local dev.
FIREBASE_ENABLED=

# Two ways to authenticate to Firebase / GCP, in order of preference:
#
# (A) ADC — Application Default Credentials (recommended, keyless)
#     Run once: gcloud auth application-default login
#     Then leave FIREBASE_CREDENTIALS_PATH unset. Spring picks up ADC from
#     ~/.config/gcloud/application_default_credentials.json.
#     Production runtime (Phase 4) uses Workload Identity Federation between
#     the deploy environment (e.g. AWS IAM role) and a GCP service account
#     — same code path, no key files anywhere.
#
# (B) Service account key file (legacy)
#     If your org policy allows, generate a key in Firebase Console ->
#     Project settings -> Service accounts -> Generate new private key.
#     Save OUTSIDE this repo (e.g. ~/Documents/secrets/<file>.json),
#     reference here as an absolute path. .env.local is gitignored, but the
#     key file itself should also live outside the repo.
FIREBASE_CREDENTIALS_PATH=

# --- CORS ---
# Comma-separated origins allowed to call this API from a browser.
# Default (dev): http://localhost:3000,http://localhost:5173 — covers Next.js
# and Vite dev servers. Production must set this to the actual web origin(s),
# e.g. CORS_ALLOWED_ORIGINS=https://pungdong.com,https://www.pungdong.com
CORS_ALLOWED_ORIGINS=

# --- 강사 신청 / 어드민 (instructor-application) ---
# 어드민 지정 allowlist. 부팅 시 이 이메일 계정에 ROLE_ADMIN 부여(idempotent).
# 계정은 먼저 일반 가입돼 있어야 하고, 설정 후 재기동하면 승격됨. 비우면 어드민 없음.
# 여러 명이면 콤마구분, 공백 없이 (셸 source 라 공백 있으면 따옴표 필요):
#   ADMIN_EMAILS=me@plop.cool,ops@plop.cool
ADMIN_EMAILS=

# 자격증 이미지 저장소. 비워두면(false) dev = 로컬 디스크(./local-uploads)에 저장 +
# /local-uploads/** 로 서빙. prod(S3 버킷 provision 후)만 true 로.
STORAGE_S3_ENABLED=
# (선택) 로컬 저장 경로 / 서빙 base URL — 기본값 local-uploads / http://localhost:8080.
# FE 가 다른 호스트면 base URL 을 실제 접근 가능한 주소로.
STORAGE_LOCAL_DIR=
STORAGE_LOCAL_BASE_URL=

# 본인확인(간편인증) 모드: stub | disabled.
# dev 기본 stub(즉시 통과, 실 본인확인기관 미연동). prod 는 실연동 전까지 disabled(fail-closed).
IDENTITY_VERIFICATION_MODE=

# --- 약관 콘텐츠 (Sanity, consent 도메인) ---
# 동의 기록 시 BE 가 (key,version) 으로 약관 전문을 Sanity 에서 직접 받아 박제한다.
# public dataset 읽기라 토큰 불필요. projectId 는 공개값(FE 와 동일) — 기본 rc448mwo 면 비워도 됨.
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_API_VERSION=

# --- 주소 검색 + 좌표 변환 (juso, address 도메인) ---
# 좌표제공 API 는 개발용 승인키가 없어 로컬은 stub 기본(고정 좌표). 실호출은 staging/prod 에서만.
# ADDRESS_GEOCODE_MODE=juso 로 전환 시 키 2개(검색/좌표) + 등록 URL(referer) 필요.
ADDRESS_GEOCODE_MODE=
JUSO_SEARCH_KEY=
JUSO_COORD_KEY=
JUSO_REFERER=
