# direnv configuration. Loads runtime secrets from .env.local (gitignored).
# Run `direnv allow` once after editing this file.
#
# Setup if direnv is not installed:
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc
#   exec zsh
#
# Then create .env.local from .env.example and fill in real values.

dotenv_if_exists .env.local
